rules_version = '2';

// Brotherhood Portal — multi-tenant isolation rules.
// Client SDK is READ-ONLY except event RSVPs. All mutations flow through
// Next.js Server Actions using the Admin SDK (which bypasses these rules);
// these rules protect against direct client access.
service cloud.firestore {
  match /databases/{db}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isSuper() {
      return signedIn() && request.auth.token.superAdmin == true;
    }
    // Custom claims shape: { superAdmin?: true, orgs: { [orgId]: { r: 'admin'|'officer'|'member', m: memberId } } }
    function orgEntry(orgId) {
      return request.auth.token.orgs[orgId];
    }
    function isMember(orgId) {
      return signedIn() && (isSuper() || (('orgs' in request.auth.token) && orgId in request.auth.token.orgs));
    }
    function isOfficer(orgId) {
      return signedIn() && (isSuper() || (isMember(orgId) && orgEntry(orgId).r in ['officer', 'admin']));
    }
    function isOrgAdmin(orgId) {
      return signedIn() && (isSuper() || (isMember(orgId) && orgEntry(orgId).r == 'admin'));
    }
    function myMemberId(orgId) {
      return orgEntry(orgId).m;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isSuper());
      allow write: if false;
    }

    match /domains/{hostname} {
      allow read: if true;
      allow write: if false;
    }

    match /platformAuditLogs/{logId} {
      allow read: if isSuper();
      allow write: if false;
    }

    match /organizations/{orgId} {
      allow read: if isMember(orgId);
      allow write: if false;

      match /branding/{docId} {
        allow read: if isMember(orgId);
        allow write: if false;
      }
      match /ranks/{rankId} {
        allow read: if isMember(orgId);
        allow write: if false;
      }
      match /activityTypes/{typeId} {
        allow read: if isMember(orgId);
        allow write: if false;
      }
      match /members/{memberId} {
        allow read: if isMember(orgId);
        allow write: if false;

        // Officer-only: isolated as a subcollection so document-level rules can gate it.
        match /notes/{noteId} {
          allow read: if isOfficer(orgId);
          allow write: if false;
        }
        match /serviceRecord/{entryId} {
          allow read: if isMember(orgId);
          allow write: if false;
        }
      }
      match /activities/{activityId} {
        // Activity feed is club-visible by design (v1).
        allow read: if isMember(orgId);
        allow write: if false;
      }
      match /patches/{patchId} {
        allow read: if isMember(orgId);
        allow write: if false;
      }
      match /awardedPatches/{awardId} {
        allow read: if isMember(orgId);
        allow write: if false;
      }
      match /cutLayouts/{memberId} {
        allow read: if isMember(orgId);
        allow write: if false;
      }
      match /prospectProfiles/{memberId} {
        allow read: if isMember(orgId);
        allow write: if false;

        match /tasks/{taskId} {
          allow read: if isMember(orgId);
          allow write: if false;
        }
        match /notes/{noteId} {
          allow read: if isOfficer(orgId);
          allow write: if false;
        }
      }
      match /votes/{voteId} {
        allow read: if isMember(orgId);
        allow write: if false;

        match /ballots/{memberId} {
          // Anonymous ballots are never client-readable; tallied results live on the vote doc.
          allow read: if isOrgAdmin(orgId)
            && get(/databases/$(db)/documents/organizations/$(orgId)/votes/$(voteId)).data.anonymous == false;
          allow write: if false;
        }
      }
      match /events/{eventId} {
        allow read: if isMember(orgId);
        allow write: if false;

        match /rsvps/{memberId} {
          allow read: if isMember(orgId);
          // The single client-writable surface: members RSVP for themselves.
          allow write: if isMember(orgId)
            && myMemberId(orgId) == memberId
            && request.resource.data.keys().hasOnly(['status', 'respondedAt'])
            && request.resource.data.status in ['going', 'maybe', 'no'];
        }
        match /attendance/{memberId} {
          allow read: if isMember(orgId);
          allow write: if false;
        }
      }
      match /gallery/{photoId} {
        allow read: if isOfficer(orgId)
          || (isMember(orgId)
              && (resource.data.status == 'approved'
                  || resource.data.uploadedByMemberId == myMemberId(orgId)));
        allow write: if false;
      }
      match /timeline/{entryId} {
        allow read: if isMember(orgId);
        allow write: if false;
      }
      match /auditLogs/{logId} {
        allow read: if isOrgAdmin(orgId);
        allow write: if false;
      }
      match /invites/{inviteId} {
        // Token exchange is server-only.
        allow read, write: if false;
      }
      match /applications/{uid} {
        // Officers triage the queue; an applicant may read their own status.
        // Created/updated only via server actions (Admin SDK).
        allow read: if isOfficer(orgId) || (signedIn() && request.auth.uid == uid);
        allow write: if false;
      }
    }

    // Default deny — also blocks collection-group queries from clients.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
